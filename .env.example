# Web サイトの公開 URL（OGP / メタデータ用）
NEXT_PUBLIC_APP_URL=https://connect2026.jpstripes.com

# webhook Worker の公開集計エンドポイント。
# 「X枚売れました」表示のためブラウザから fetch する（PII を含まない種別ごとの累計）。
# 未設定の場合、申込枚数の表示は出ない。
# 例: https://jpstripes-connect-2026-webhook.wp-kyoto.workers.dev/stats
NEXT_PUBLIC_STATS_API_URL=https://jpstripes-connect-2026-webhook.wp-kyoto.workers.dev/stats
